      "parameters": {
        "jsCode": "const items = $input.all();\nconst elements = [];\n\nlet senderId;\ntry {\n  senderId = $(\"Webhook\").first().json.body.entry[0].messaging[0].sender.id;\n} catch (e) {\n  senderId = \"26120025164298627\"; \n}\n\nitems.slice(0, 10).forEach(item => {\n  // Ekhane sure hobe j column nam 'Product Name (Bangla)' ebong 'Product ID' ki na\n  const productName = item.json[\"Product Name (Bangla)\"] || \"Unknown\";\n  const productId = item.json[\"Product ID\"] || \"NoID\"; \n  \n  elements.push({\n    \"title\": productName,\n    \"image_url\": item.json[\"Product Image Link (Public)\"],\n    \"subtitle\": (item.json[\"Price (৳)\"] || \"0\") + \" Tk\",\n    \"buttons\": [\n      {\n        \"type\": \"postback\",\n        \"title\": \"Order Now\",\n        // Ekhane amra dynamic productId variable-ti use korchi\n        \"payload\": \"ORDER_ITEM_\" + productName + \"_\" + productId\n      }\n    ]\n  });\n});\n\nreturn {\n  recipient_id: senderId,\n  elements: elements\n};"
      },
