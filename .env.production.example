# Production environment template for ZamZam ERP.
# Copy to `.env` on the server and fill in real values. This differs from
# `.env.example` (which targets local development) in the security- and
# scalability-critical settings called out below.

APP_NAME="ZamZam ERP"
# MUST be `production` (not `local`) and debug MUST be off, or the app leaks
# stack traces and configuration to visitors.
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-domain.com
ASSET_URL=
ADMIN_APP_HOST=app.your-domain.com
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Keep production logs quiet; `debug` is far too noisy.
LOG_LEVEL=warning

# ---------------------------------------------------------------------------
# Database — DO NOT run production on SQLite.
# SQLite allows only one writer at a time; the storefront, admin panel,
# courier webhooks and scheduled jobs all write concurrently and will hit
# "database is locked" errors under load. Use MySQL 8+ or PostgreSQL.
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zamzam_erp
DB_USERNAME=zamzam
DB_PASSWORD=

# Strong password (12+ chars, mixed case, number, symbol) used once by the
# initial `php artisan db:seed`.
ADMIN_NAME="ZamZam Admin"
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=

BACKUP_RETAIN_FILES=10
BACKUP_SCHEDULE_TIME=02:00
GOOGLE_DRIVE_BACKUP_ENABLED=false
GOOGLE_DRIVE_BACKUP_AUTO_UPLOAD=false
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Sessions/cache should not use the local filesystem in a multi-process /
# multi-server deployment. database or redis keeps them consistent.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# Queue — DO NOT use `sync` in production.
# With `sync`, jobs run inside the web request: courier webhooks and the
# external courier fraud check (which logs into merchant panels) would block
# checkout and webhook responses, and job retries/backoff never fire.
# Use `database` (needs the jobs table + a running worker) or `redis`, and run
# `php artisan queue:work` as a supervised process (systemd / supervisor).
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="admin@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
