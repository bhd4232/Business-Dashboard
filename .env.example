# This file targets LOCAL DEVELOPMENT. For production, copy
# `.env.production.example` instead — production must set APP_ENV=production,
# APP_DEBUG=false, a real database (not sqlite), and a non-sync queue driver.
APP_NAME="Business Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL=
# Host the Filament admin panel / Android app shell loads (e.g. app.zamzamint.com).
# Visiting "/" on this host redirects straight into /admin instead of the marketing page.
ADMIN_APP_HOST=
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_VERSION=1.21.0
APP_RELEASE_TYPE=minor
APP_RELEASE_DATE=2026-07-23

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=business_dashboard
# DB_USERNAME=root
# DB_PASSWORD=

# Optional isolated demo database. Run `php artisan demo:refresh`, then set
# DB_CONNECTION=demo locally if you want to browse demo data without touching
# your main database.
DEMO_DB_DATABASE=database/demo.sqlite

ADMIN_NAME="ZamZam Admin"
ADMIN_EMAIL=admin@example.com
# Required for `php artisan db:seed`; use at least 12 characters with uppercase,
# lowercase, number, and symbol.
ADMIN_PASSWORD=

BACKUP_RETAIN_FILES=10
BACKUP_SCHEDULE_TIME=02:00
GOOGLE_DRIVE_BACKUP_ENABLED=false
GOOGLE_DRIVE_BACKUP_AUTO_UPLOAD=false
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Safe default for SQLite/local/small installs. For larger MySQL/Redis deployments,
# database or redis drivers can be used with a queue worker.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Replace with a real business email before enabling outbound mail.
MAIL_FROM_ADDRESS="admin@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 (optional, S3-compatible object storage). Only needed if/when
# the storefront's "public" disk is migrated off local server disk. Leave
# blank until a bucket + API token are created in the Cloudflare dashboard.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=

# Meta Graph API version shared by WhatsApp Cloud API and Messenger.
META_GRAPH_API_VERSION=v25.0
META_MAX_MEDIA_BYTES=26214400

VITE_APP_NAME="${APP_NAME}"
